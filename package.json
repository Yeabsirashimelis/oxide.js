{
  "name": "oxide.js",
  "version": "0.1.0",
  "description": "A modern TypeScript-first backend framework",
  "main": "dist/lib.js",
  "module": "dist/lib.mjs",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/lib.d.mts",
        "default": "./dist/lib.mjs"
      },
      "require": {
        "types": "./dist/lib.d.ts",
        "default": "./dist/lib.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "demo": "npx tsx src/index.ts",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "http",
    "framework",
    "node",
    "typescript",
    "backend",
    "server",
    "websocket",
    "middleware",
    "rest",
    "api"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "ejs": "^5.0.1",
    "ws": "^8.20.0"
  }
}
